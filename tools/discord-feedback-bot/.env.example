DISCORD_TOKEN=your-discord-bot-token
DISCORD_FEEDBACK_CHANNEL_ID=your-forum-channel-id
FEEDBACK_API_PORT=8788

# Optional: list of user IDs that should be treated as reviewer replies.
DISCORD_REVIEWER_USER_IDS=123456789012345678,234567890123456789

# Optional: list of role IDs that should be treated as reviewer replies.
DISCORD_REVIEWER_ROLE_IDS=123456789012345678,234567890123456789

# Optional: local JSON file mirror output for the mockup app.
# The same file is also served by GET /feedback-feed.json from the bot service.
MIRROR_OUTPUT_PATH=./feedback-feed.json

# Optional: remote POST endpoint if you want to push the full feed elsewhere.
MIRROR_PUSH_URL=
